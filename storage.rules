rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default: Authenticated users only
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.admin == true || get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Profile pictures: User can read all, but only upload their own
    match /profile_pictures/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

